<%- include("partials/header.ejs") %>

<main class="content-wrapper">
  <section class="hero">
    <h2 class="hero-title">Edits</h2>
    <% if (locals.bookData && bookData.postISBN) { %>
      <div class="cover-preview-container">
        <img id="cover-preview" 
          src="https://covers.openlibrary.org/b/isbn/<%= bookData.postISBN %>-M.jpg" 
          alt="Book Cover" 
          style="max-width: 150px; margin-bottom: 20px;">
      </div>
    <% } %>
  </section>

  <form class="book-form" action="/save-note" method="POST">
    <input type="hidden" name="postID" value="<%= bookData.postID %>">

    <div class="form-group form-group-inline">
      <label for="book-isbn" class="form-label">ISBN</label>
      <input type="text" id="book-isbn" name="isbn" class="input-sub" 
        value="<%= bookData.postISBN %>" readonly>
    </div>

    <div class="form-group">
      <label for="book-title" class="form-label">Book Title</label>
      <input type="text" id="book-title" name="title" class="input-title" 
        value="<%= bookData.postTitle %>" readonly>
    </div>

    <div class="form-group">
      <label for="book-summary" class="form-label">Summary</label>
      <textarea id="book-summary" name="summary" class="input-summary" required><%= bookData.postSnippet %></textarea>
    </div>

    <div class="form-group">
      <label for="book-body" class="form-label">Notes</label>
      <textarea id="book-body" name="notes" class="input-main"><%= bookData.postNotes %></textarea>
    </div>

    <div class="form-group">
      <label class="form-label">Rating</label>
      <div class="book-rating">
        <% for(let i = 1; i <= 10; i++) { %>
          <input type="radio" name="rating" value="<%= i %>" id="rate-<%= i %>" class="radio-input" 
            <%= bookData.postRating == i ? 'checked' : '' %> required>
          <label for="rate-<%= i %>" class="rating-button"><%= i %></label>
        <% } %>
      </div>
    </div>

    <div class="edit-actions">
      <button type="submit" class="submit-btn">Save Notes</button>
      
      <button type="submit" formaction="/delete-note" class="delete-btn-red">Delete Notes</button>
    </div>
  </form>
</main>

<%- include("partials/footer.ejs") %>